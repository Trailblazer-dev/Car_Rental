{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "prebuild": "node scripts/copy-assets.js",
    "build": "vite build --outDir dist --assetsDir assets --mode production",
    "postbuild": "cp staticwebapp.config.json dist/",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "rm -rf node_modules package-lock.json dist",
    "swa:start": "npx swa start",
    "swa:build": "node scripts/prepare-swa-build.js && npm run prebuild && vite build --outDir dist --assetsDir assets && npm run postbuild",
    "swa:deploy": "npx swa deploy --env production",
    "swa:build:clean": "npm run clean && npm install --no-audit --no-fund && npm run swa:build",
    "swa:config": "npx swa init --yes",
    "fix:react": "node scripts/fix-react-for-azure.js",
    "prepare:azure": "node scripts/azure-deploy-fix.js",
    "build:azure": "node scripts/azure-build-fix.js",
    "prepare:swa": "node scripts/prepare-swa-build.js"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^24.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "axios": "^1.6.2",
    "lucide-react": "^0.288.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^1.1.4",
    "@eslint/js": "^8.56.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react-swc": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "globals": "^13.24.0",
    "postcss": "^8.4.31",
    "rollup": "^3.28.1",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "typescript-eslint": "^0.0.1-alpha.0",
    "vite": "^4.5.0"
  }
}
